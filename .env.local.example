# ─── API Backend ──────────────────────────────────────────────────────────────
# URL do crescix-api (Fastify). Em produção, aponte para o domínio do Render.
#
# Em desenvolvimento, mantenha localhost:3333 (default) e suba o backend com:
#   cd ../crescix-api && npm run dev
NEXT_PUBLIC_API_URL=http://localhost:3333

# ─── Bots (opcional) ──────────────────────────────────────────────────────────
# Username do bot Telegram, SEM o "@". Aparece no link de pareamento do /perfil.
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=crescix_dev_bot

# ─── Mercado Pago — pagamento por cartão (opcional) ─────────────────────────────
# Public Key da sua aplicação no Mercado Pago. NÃO é o access token — é a chave
# PÚBLICA mesmo (fica embutida no bundle do front, é esperado). Usada pelo SDK
# do MP pra tokenizar o cartão no navegador. Sem ela, a aba "Cartão" não funciona.
#   Produção começa com "APP_USR-"  |  Sandbox/teste começa com "TEST-"
#   (pegar no painel do MP → sua app → Credenciais → Public Key)
# NEXT_PUBLIC_MP_PUBLIC_KEY=cole-sua-public-key-aqui

# Feature flag do cartão de crédito. Default ON (ausente = habilitado).
# Setar "false" esconde a aba "Cartão" no checkout SEM precisar de deploy —
# útil enquanto a Preapproval API não está habilitada na conta do MP.
# NEXT_PUBLIC_CREDIT_CARD_ENABLED=true

# ─── Sentry — monitoramento de erros (opcional) ─────────────────────────────────
# Sem essas vars, o SDK do Sentry fica em no-op (dev/CI rodam sem custo).
# NEXT_PUBLIC_SENTRY_DSN é exposta no bundle (esperado); SENTRY_DSN é o
# equivalente server-side. Use o mesmo valor nas duas.
# NEXT_PUBLIC_SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx
# SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx
#
# Opcionais — só pra upload de source maps no build (stack trace simbolizado):
# SENTRY_ORG=seu-org-slug
# SENTRY_PROJECT=crescix-web
# SENTRY_AUTH_TOKEN=sntrys_xxxx
